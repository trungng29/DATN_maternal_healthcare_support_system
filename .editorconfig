# EditorConfig — consistent coding styles across editors & IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.{java,kt,cs,go,rs}]
indent_size = 4

[Makefile]
indent_style = tab
